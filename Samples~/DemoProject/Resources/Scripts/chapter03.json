{
  "title": "第3章：それぞれの結末",
  "commands": [
    { "type": "show_bg", "image": "bg_room", "value": "fade_black", "duration": 1.0 },
    { "type": "show_title", "text": "第3章：それぞれの結末", "duration": 3.0 },
    { "type": "fade", "value": "in", "duration": 1.0 },

    { "type": "say", "text": "卒業式の朝。桜の花びらが風に舞っている。" },

    { "type": "jump_if", "label": "walked_together", "target": "ending_true" },
    { "type": "jump_if", "label": "friendly", "target": "ending_normal" },
    { "type": "jump_if", "label": "apologized", "target": "ending_reconcile" },
    { "type": "jump", "target": "ending_alone" },

    { "type": "label", "label": "ending_true" },
    { "type": "show_char", "character": "alice", "position": "center", "value": "slide_right", "duration": 0.5 },
    { "type": "say", "character": "アリス", "text": "ねえ、覚えてる？　初めて会った日のこと。" },
    { "type": "say", "text": "あの日からずっと、一緒に歩いてきた。" },
    { "type": "say", "character": "アリス", "text": "これからも……一緒にいてくれる？" },
    { "type": "say", "text": "桜が二人を祝福するように降り注ぐ。" },
    { "type": "say", "text": "――True End: 『桜の約束』――" },
    { "type": "hide_char", "character": "alice", "value": "zoom_out" },
    { "type": "fade", "value": "out", "duration": 2.0 },
    { "type": "end", "label": "True End: 桜の約束" },

    { "type": "label", "label": "ending_normal" },
    { "type": "show_char", "character": "alice", "position": "center", "value": "bounce" },
    { "type": "say", "character": "アリス", "text": "転校生くん！　卒業おめでとう！" },
    { "type": "say", "text": "いつもの笑顔。それだけで、十分だった。" },
    { "type": "say", "character": "アリス", "text": "大学は違うけど……また会おうね！" },
    { "type": "say", "text": "――Normal End: 『いつもの笑顔』――" },
    { "type": "hide_char", "character": "alice", "value": "slide_left" },
    { "type": "fade", "value": "out", "duration": 2.0 },
    { "type": "end", "label": "Normal End: いつもの笑顔" },

    { "type": "label", "label": "ending_reconcile" },
    { "type": "show_char", "character": "alice", "position": "center", "value": "zoom_in", "duration": 0.4 },
    { "type": "say", "text": "式の後、彼女が近づいてきた。" },
    { "type": "say", "character": "アリス", "text": "あの時……謝ってくれたこと、ずっと覚えてた。" },
    { "type": "say", "character": "アリス", "text": "ありがとう。あれで救われたんだ。" },
    { "type": "say", "text": "もっと早く、素直になればよかった。" },
    { "type": "say", "text": "――Bittersweet End: 『遅すぎた言葉』――" },
    { "type": "hide_char", "character": "alice" },
    { "type": "fade", "value": "out", "duration": 2.0 },
    { "type": "end", "label": "Bittersweet End: 遅すぎた言葉" },

    { "type": "label", "label": "ending_alone" },
    { "type": "say", "text": "式が終わっても、話しかけてくる人はいなかった。" },
    { "type": "say", "text": "桜の花びらが、一人の肩に落ちる。" },
    { "type": "say", "text": "――あの日、手を伸ばしていれば。" },
    { "type": "say", "text": "――Bad End: 『孤独な桜』――" },
    { "type": "fade", "value": "out", "duration": 2.0 },
    { "type": "end", "label": "Bad End: 孤独な桜" }
  ]
}
