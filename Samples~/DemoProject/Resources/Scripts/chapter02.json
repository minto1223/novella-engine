{
  "title": "第2章：すれ違いの放課後",
  "commands": [
    { "type": "show_bg", "image": "bg_room" },
    { "type": "show_title", "text": "第2章：すれ違いの放課後", "duration": 3.0 },
    { "type": "fade", "value": "in", "duration": 1.0 },
    { "type": "say", "text": "放課後の教室。窓から差し込む夕日が、机を橙色に染めていた。" },

    { "type": "jump_if", "label": "friendly", "target": "ch2_friendly" },

    { "type": "say", "text": "あの日以来、彼女とはほとんど話していない。" },
    { "type": "say", "text": "教室に残っているのは、自分ひとりだけだ。" },
    { "type": "say", "text": "……帰ろう。" },
    { "type": "show_char", "character": "alice", "position": "center" },
    { "type": "say", "text": "――と、立ち上がった瞬間。ドアが開いた。" },
    { "type": "say", "character": "アリス", "text": "あ……まだ、いたんだ。" },
    { "type": "say", "text": "彼女は少し驚いた顔をしたが、すぐに目をそらした。" },

    { "type": "choice", "choices": [
      { "text": "この前はごめん",     "target": "ch2_apologize", "set_flag": "apologized", "flag_value": "true" },
      { "text": "（何も言わない）", "target": "ch2_silent" }
    ]},

    { "type": "label", "label": "ch2_apologize" },
    { "type": "say", "character": "アリス", "text": "え……？" },
    { "type": "say", "character": "アリス", "text": "……ううん、私こそ急に話しかけてごめんね。" },
    { "type": "say", "character": "アリス", "text": "でも、そう言ってくれて嬉しい。ありがとう。" },
    { "type": "say", "text": "彼女の表情が、少しだけ和らいだ気がした。" },
    { "type": "jump", "target": "ch2_ending" },

    { "type": "label", "label": "ch2_silent" },
    { "type": "say", "text": "言葉が見つからないまま、時間だけが過ぎていく。" },
    { "type": "say", "character": "アリス", "text": "……じゃあ、私帰るね。" },
    { "type": "say", "text": "彼女は足早に教室を出ていった。" },
    { "type": "jump", "target": "ch2_ending" },

    { "type": "label", "label": "ch2_friendly" },
    { "type": "show_char", "character": "alice", "position": "center" },
    { "type": "say", "character": "アリス", "text": "あ、まだいたんだ！　一緒に帰らない？" },
    { "type": "say", "text": "あの日から、アリスとはよく話すようになっていた。" },

    { "type": "choice", "choices": [
      { "text": "いいよ、帰ろう",     "target": "ch2_walk_together", "set_flag": "walked_together", "flag_value": "true" },
      { "text": "今日はちょっと用事がある", "target": "ch2_decline" }
    ]},

    { "type": "label", "label": "ch2_walk_together" },
    { "type": "say", "character": "アリス", "text": "やった！　実はね、帰り道に気になるお店見つけたの。" },
    { "type": "say", "character": "アリス", "text": "一緒に寄ってみない？" },
    { "type": "say", "text": "夕日に照らされた通学路を、二人で歩く。" },
    { "type": "say", "text": "なんでもない会話が、不思議と心地よかった。" },
    { "type": "jump", "target": "ch2_ending" },

    { "type": "label", "label": "ch2_decline" },
    { "type": "say", "character": "アリス", "text": "そっか、残念。じゃあまた明日ね！" },
    { "type": "say", "text": "アリスは手を振って先に帰っていった。" },
    { "type": "say", "text": "……本当は、用事なんてなかったのに。" },

    { "type": "label", "label": "ch2_ending" },
    { "type": "hide_char", "character": "alice" },
    { "type": "say", "text": "――帰り道、夕焼けがいつもより綺麗に見えた。" },
    { "type": "fade", "value": "out", "duration": 1.0 },
    { "type": "next_script", "target": "Scripts/chapter03" }
  ]
}
